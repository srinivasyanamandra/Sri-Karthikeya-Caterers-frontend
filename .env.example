# Example environment configuration for Sri Karthikeya Caterers frontend.
# 
# USAGE:
# - For local development: Copy this to .env (already done)
# - For custom local config: Copy this to .env.local and customize
# - Production uses .env.production automatically

# App metadata
REACT_APP_NAME=Sri Karthikeya Caterers
REACT_APP_VERSION=1.0.0

# Backend API URL
# Local development (default in .env):
# REACT_APP_API_URL=http://localhost:8080

# Production (set in .env.production):
REACT_APP_API_URL=https://skc-backend-5o4z.onrender.com
